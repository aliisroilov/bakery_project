# ──────────────────────────────────────────────
# V2 production environment
# Copy to `.env` on the server and fill in real values.
# ──────────────────────────────────────────────

# Security
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_50_CHAR_STRING
DEBUG=False
ALLOWED_HOSTS=v2.sutli-non.uz,www.v2.sutli-non.uz

# Database — NEW PostgreSQL DB, separate from v1's bakery_db
DATABASE_URL=postgres://bakery_v2:CHANGE_ME@localhost:5432/bakery_v2

# Redis (can share V1's Redis if it has one, use different DB index)
REDIS_URL=redis://localhost:6379/1

# CORS — frontend origin(s) allowed to call the API
CORS_ALLOWED_ORIGINS=https://v2.sutli-non.uz

# JWT
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14
