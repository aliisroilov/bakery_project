# Copy this file to .env and fill in your values
# cp .env.example .env

# Django
SECRET_KEY=your-strong-secret-key-here
DEBUG=False

# Allowed hosts (comma-separated)
# ALLOWED_HOSTS=sutli-non.uz,www.sutli-non.uz,localhost

# PostgreSQL (V1)
POSTGRES_DB=bakery_db
POSTGRES_USER=bakuser
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PostgreSQL (V2 — separate database)
# V2_POSTGRES_DB=bakery_v2
# V2_POSTGRES_USER=bakuser_v2
# V2_POSTGRES_PASSWORD=your-v2-db-password
# V2_POSTGRES_HOST=localhost
# V2_POSTGRES_PORT=5432

# V2 JWT (generate with: python -c "import secrets; print(secrets.token_hex(64))")
# SECRET_KEY_V2=your-v2-secret-key
